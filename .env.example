# ---- MongoDB (use your MongoDB Atlas connection string) ----
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=tweet_views

# ---- SMM panel (dnoxsmm) ----
SMM_API_URL=https://dnoxsmm.com/api/v2
SMM_API_KEY=your_panel_api_key
# Find this by hitting /api/services?q=views once the app is running
VIEWS_SERVICE_ID=0
ORDER_MIN_QTY=3000
ORDER_MAX_QTY=4000

# ---- Twitter provider: twitterapi_io (cheap) or x_official (needs Basic tier) ----
TWITTER_PROVIDER=twitterapi_io
TWITTERAPI_IO_KEY=your_twitterapi_io_key
X_BEARER_TOKEN=

# ---- Behaviour ----
POLL_INTERVAL_SECONDS=60
ONLY_ORIGINAL_TWEETS=true
DRY_RUN=false

# ---- Admin auth (protects the dashboard + API) ----
ADMIN_TOKEN=set_a_long_random_string

# ---- Telegram notifications (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
